\textbf{2.4 Operating Environment}

\begin{itemize}
\item
  Web browsers: Chrome, Firefox, Safari, Edge (latest versions).
\item
  Devices: Desktop, laptop, and mobile devices (responsive design).
\item
  Server Environment: PHP, MySQL (InnoDB), Apache/Nginx.
\end{itemize}

\textbf{2.5 Constraints}

\begin{itemize}
\item
  The application must be fully responsive and optimized for mobile exams.
\item
  All pages must use HTTPS to keep user data safe.
\end{itemize}

\textbf{2.6 Assumptions and Dependencies}

\textbf{2.6.1 Assumptions}

\begin{itemize}
\item
  Users have a stable internet connection during exam sessions to save snapshots.
\item
  All users provide real and accurate personal information when registering.
\end{itemize}

\textbf{2.6.2 Dependencies}

\begin{itemize}
\item
  Google API is available for OAuth authentication.
\end{itemize}

