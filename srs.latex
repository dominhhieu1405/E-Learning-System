\textbf{3. Specific Functional Requirements}

This section describes the detailed functional requirements of the user interface using standardized use case tables.

\textbf{3.1 FR-001 --- User Authentication (Login/Register)}

\begin{longtable}[]{@{}
  >{\raggedright\arraybackslash}p{(\columnwidth - 2\tabcolsep) * \real{0.2137}}
  >{\raggedright\arraybackslash}p{(\columnwidth - 2\tabcolsep) * \real{0.7863}}@{}}
\toprule()
\endhead
\textbf{Use Case Name} & User Authentication \\
\textbf{Use Case ID} & FR-001 \\
\textbf{XRef} & Section 2.2, FR-001 \\
\textbf{Actor} & Student \\
\textbf{Trigger} & User clicks "Login" or "Register" on the homepage. \\
\textbf{Precondition} & User has a valid email or a Google account. \\
\textbf{Basic Path} & \begin{minipage}[t]{\linewidth}\raggedright
\begin{quote}
1. User selects standard login or "Login with Google".

2. If standard, user enters credentials; system validates against database.

3. If Google, user is redirected to Google OAuth; upon success, system checks or creates account.

4. System creates session and redirects to Home or Profile.
\end{quote}
\end{minipage} \\
\textbf{Alternative Paths} & If email exists during Google login, link account. If invalid standard credentials, show error. \\
\textbf{Postcondition} & User is authenticated and can access personalized content. \\
\textbf{Exception Paths} & Login fails due to incorrect password or network error. \\
\textbf{Other} & Account locked after 5 failed attempts for security. \\
\bottomrule()
\end{longtable}

\textbf{3.2 FR-002 --- Profile Management}

\begin{longtable}[]{@{}
  >{\raggedright\arraybackslash}p{(\columnwidth - 2\tabcolsep) * \real{0.2137}}
  >{\raggedright\arraybackslash}p{(\columnwidth - 2\tabcolsep) * \real{0.7863}}@{}}
\toprule()
\endhead
\textbf{Use Case Name} & Profile Management \\
\textbf{Use Case ID} & FR-002 \\
\textbf{XRef} & Section 2.2, FR-002 \\
\textbf{Actor} & Student \\
\textbf{Trigger} & User clicks on their avatar and selects "Profile". \\
\textbf{Precondition} & User is logged into the system. \\
\textbf{Basic Path} & \begin{minipage}[t]{\linewidth}\raggedright
\begin{quote}
1. User views their current profile details (Name, Email).

2. User edits display name or uploads a new avatar.

3. User submits the changes.

4. System updates the database and displays a success message.
\end{quote}
\end{minipage} \\
\textbf{Alternative Paths} & If image upload fails validation (e.g., file too large), system shows an error message. \\
\textbf{Postcondition} & User profile information is updated. \\
\textbf{Exception Paths} & Database update failure, invalid image format for avatar. \\
\textbf{Other} & Profile changes are reflected across the system immediately. \\
\bottomrule()
\end{longtable}

\textbf{3.3 FR-003 --- Exam Browsing \& Search}

\begin{longtable}[]{@{}
  >{\raggedright\arraybackslash}p{(\columnwidth - 2\tabcolsep) * \real{0.2137}}
  >{\raggedright\arraybackslash}p{(\columnwidth - 2\tabcolsep) * \real{0.7863}}@{}}
\toprule()
\endhead
\textbf{Use Case Name} & Exam Browsing \& Search \\
\textbf{Use Case ID} & FR-003 \\
\textbf{XRef} & Section 2.2, FR-003 \\
\textbf{Actor} & Student \\
\textbf{Trigger} & User navigates to the "Exams" page or uses the search bar. \\
\textbf{Precondition} & None. \\
\textbf{Basic Path} & \begin{minipage}[t]{\linewidth}\raggedright
\begin{quote}
1. System displays a paginated list of available exams.

2. User filters exams by type (THPT, HSA, TSA) or searches by keyword.

3. User clicks on an exam card.

4. System shows the Exam Detail page containing duration, number of questions, and description.
\end{quote}
\end{minipage} \\
\textbf{Postcondition} & User is on the Exam Detail page, ready to start. \\
\textbf{Exception Paths} & No exams found matching the search criteria. \\
\textbf{Other} & Search is case-insensitive. \\
\bottomrule()
\end{longtable}

\textbf{3.4 FR-004 --- Exam Execution}

\begin{longtable}[]{@{}
  >{\raggedright\arraybackslash}p{(\columnwidth - 2\tabcolsep) * \real{0.2137}}
  >{\raggedright\arraybackslash}p{(\columnwidth - 2\tabcolsep) * \real{0.7863}}@{}}
\toprule()
\endhead
\textbf{Use Case Name} & Exam Execution \\
\textbf{Use Case ID} & FR-004 \\
\textbf{XRef} & Section 2.2, FR-004 \\
\textbf{Actor} & Student \\
\textbf{Trigger} & User clicks "Start Exam" on an Exam Detail page. \\
\textbf{Precondition} & User is logged in and an exam has been selected. \\
\textbf{Basic Path} & \begin{minipage}[t]{\linewidth}\raggedright
\begin{quote}
1. System generates a unique \texttt{exam\_sessions} record and \texttt{session\_key}.

2. System renders the exam interface with a countdown timer.

3. User navigates through questions (MC, TF, matching, etc.) and inputs answers.

4. System periodically saves \texttt{snapshot} JSON via background AJAX requests to prevent data loss.

5. User clicks Submit or time expires.

6. System calculates scores and sets session status to \texttt{completed}.
\end{quote}
\end{minipage} \\
\textbf{Alternative Paths} & If user disconnects, session can be resumed via \texttt{session\_key} and snapshot. \\
\textbf{Postcondition} & Exam session is completed, results are recorded. \\
\textbf{Exception Paths} & Loss of internet connection, session timeout. \\
\textbf{Other} & Snapshots are saved every 30 seconds to prevent data loss. \\
\bottomrule()
\end{longtable}

\textbf{3.5 FR-005 --- Results \& Leaderboard}

\begin{longtable}[]{@{}
  >{\raggedright\arraybackslash}p{(\columnwidth - 2\tabcolsep) * \real{0.2137}}
