    "phpfastcache/phpfastcache": "^8.0.7",
    "intervention/image": "2.*",
    "ext-gd": "*",
    "ext-openssl": "*",
    "ext-exif": "*",
    "ext-json": "*",
    "ext-curl": "*",
    "phpmailer/phpmailer": "^6.6",
